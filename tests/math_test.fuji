// tests/math_test.fuji
let math = import "@math";

print("--- Testing Math Module ---");
print("PI: ", math.pi);
print("E:  ", math.e);

print("sin(pi/2): ", math.sin(math.pi / 2)); // Expected: 1
print("cos(pi):   ", math.cos(math.pi));     // Expected: -1
print("sqrt(16):  ", math.sqrt(16));         // Expected: 4
print("abs(-42):  ", math.abs(-42));         // Expected: 42

print("floor(3.9): ", math.floor(3.9)); // Expected: 3
print("ceil(3.1):  ", math.ceil(3.1));  // Expected: 4

let angle = math.pi / 4;
let s = math.sin(angle);
let c = math.cos(angle);
print("sin^2 + cos^2: ", s*s + c*c); // Expected: 1

print("Math tests complete!");
