    FLAG_WINDOW_MINIMIZED = 0;
const ConfigFlags_// Set to minimize window (iconify)
    FLAG_WINDOW_MAXIMIZED = 0;
const ConfigFlags_// Set to maximize window (expanded to monitor)
    FLAG_WINDOW_UNFOCUSED = 0;
const ConfigFlags_// Set to window non focused
    FLAG_WINDOW_TOPMOST = 0;
const ConfigFlags_// Set to window always on top
    FLAG_WINDOW_ALWAYS_RUN = 0;
const ConfigFlags_// Set to allow windows running while minimized
    FLAG_WINDOW_TRANSPARENT = 0;
const ConfigFlags_// Set to allow transparent framebuffer
    FLAG_WINDOW_HIGHDPI = 0;
const ConfigFlags_// Set to support HighDPI
    FLAG_WINDOW_MOUSE_PASSTHROUGH = 0;
