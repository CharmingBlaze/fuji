    CUBEMAP_LAYOUT_CROSS_FOUR_BY_THREE     // Layout is defined by a 4x3 cross with cubemap faces = 4;

// Enum: FontType
const FontType_FONT_DEFAULT = 0;
const FontType_// Default font generation = 1;
const FontType_anti-aliased
    FONT_BITMAP = 2;
const FontType_// Bitmap font generation = 3;
const FontType_no anti-aliasing
    FONT_SDF                        // SDF font generation = 4;
const FontType_requires external shader = 5;

// Enum: BlendMode
const BlendMode_BLEND_ALPHA = 0;
const BlendMode_// Blend textures considering alpha (default)
    BLEND_ADDITIVE = 1;
const BlendMode_// Blend textures adding colors
    BLEND_MULTIPLIED = 2;
const BlendMode_// Blend textures multiplying colors
    BLEND_ADD_COLORS = 3;
const BlendMode_// Blend textures adding colors (alternative)
    BLEND_SUBTRACT_COLORS = 4;
const BlendMode_// Blend textures subtracting colors (alternative)
    BLEND_ALPHA_PREMULTIPLY = 5;
const BlendMode_// Blend premultiplied textures considering alpha
    BLEND_CUSTOM = 6;
const BlendMode_// Blend textures using custom src/dst factors (use rlSetBlendFactors())
    BLEND_CUSTOM_SEPARATE           // Blend textures using custom rgb/alpha separate src/dst factors (use rlSetBlendFactorsSeparate()) = 7;

// Enum: Gesture
const Gesture_GESTURE_NONE = 0;
const Gesture_// No gesture
    GESTURE_TAP = 1;
const Gesture_// Tap gesture
    GESTURE_DOUBLETAP = 2;
const Gesture_// Double tap gesture
    GESTURE_HOLD = 4;
const Gesture_// Hold gesture
    GESTURE_DRAG = 8;
const Gesture_// Drag gesture
    GESTURE_SWIPE_RIGHT = 16;
const Gesture_// Swipe right gesture
    GESTURE_SWIPE_LEFT = 32;
const Gesture_// Swipe left gesture
    GESTURE_SWIPE_UP = 64;
const Gesture_// Swipe up gesture
    GESTURE_SWIPE_DOWN = 128;
const Gesture_// Swipe down gesture
    GESTURE_PINCH_IN = 256;
const Gesture_// Pinch in gesture
    GESTURE_PINCH_OUT = 512;

// Enum: CameraMode
const CameraMode_CAMERA_CUSTOM = 0;
const CameraMode_// Camera custom = 1;
const CameraMode_controlled by user (UpdateCamera() does nothing)
    CAMERA_FREE = 2;
const CameraMode_// Camera free mode
    CAMERA_ORBITAL = 3;
const CameraMode_// Camera orbital = 4;
const CameraMode_around target = 5;
const CameraMode_zoom supported
    CAMERA_FIRST_PERSON = 6;
const CameraMode_// Camera first person
    CAMERA_THIRD_PERSON             // Camera third person = 7;

// Enum: CameraProjection
const CameraProjection_CAMERA_PERSPECTIVE = 0;
const CameraProjection_// Perspective projection
    CAMERA_ORTHOGRAPHIC             // Orthographic projection = 1;

// Enum: NPatchLayout
const NPatchLayout_NPATCH_NINE_PATCH = 0;
const NPatchLayout_// Npatch layout: 3x3 tiles
    NPATCH_THREE_PATCH_VERTICAL = 1;
const NPatchLayout_// Npatch layout: 1x3 tiles
    NPATCH_THREE_PATCH_HORIZONTAL   // Npatch layout: 3x1 tiles = 2;


