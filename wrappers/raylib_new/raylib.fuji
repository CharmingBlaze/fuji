const TextureFilter_// Anisotropic filtering 8x
    TEXTURE_FILTER_ANISOTROPIC_16X = 6;
const TextureFilter_// Anisotropic filtering 16x = 7;

// Enum: TextureWrap
const TextureWrap_TEXTURE_WRAP_REPEAT = 0;
const TextureWrap_// Repeats texture in tiled mode
    TEXTURE_WRAP_CLAMP = 1;
const TextureWrap_// Clamps texture to edge pixel in tiled mode
    TEXTURE_WRAP_MIRROR_REPEAT = 2;
const TextureWrap_// Mirrors and repeats the texture in tiled mode
    TEXTURE_WRAP_MIRROR_CLAMP               // Mirrors and clamps to border the texture in tiled mode = 3;

// Enum: CubemapLayout
const CubemapLayout_CUBEMAP_LAYOUT_AUTO_DETECT = 0;
const CubemapLayout_// Automatically detect layout type
    CUBEMAP_LAYOUT_LINE_VERTICAL = 1;
const CubemapLayout_// Layout is defined by a vertical line with faces
    CUBEMAP_LAYOUT_LINE_HORIZONTAL = 2;
const CubemapLayout_// Layout is defined by a horizontal line with faces
    CUBEMAP_LAYOUT_CROSS_THREE_BY_FOUR = 3;
