// tests/native_test.fuji
print("Testing Native Compilation...");

func add(x, y) {
    return x + y;
}

let result = add(5, 10);
print("5 + 10 = " + result);

if (result > 10) {
    print("Result is greater than 10");
}

let items = [10, 20, 30];
print("Array item 1: " + items[1]);

func test_closures() {
    let x = 10;
    func inner() {
        print("Captured X: " + x);
        x = x + 1;
    }
    inner();
    inner();
    print("X after inner calls: " + x);
}
func test_loops() {
    print("Testing While Loop:");
    let i = 0;
    while (i < 3) {
        print("i = " + i);
        i = i + 1;
    }

    print("Testing For Loop:");
    for (let j = 0; j < 3; j = j + 1) {
        print("j = " + j);
    }
}
test_loops();
test_closures();

print("Native test done.");
