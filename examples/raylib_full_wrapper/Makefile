# Makefile for raylib wrapper
# Generated by WrapGen

CC = gcc
CXX = g++
CFLAGS = -Wall -O2 -fPIC
CXXFLAGS = -Wall -O2 -fPIC -std=c++11
LDFLAGS = -shared
LIBRARY = raylib
WRAPPER = wrapper
VERSION = 1.0.0

# Source files
SOURCES = wrapper.c
CPP_SOURCES = wrapper.cpp
OBJECTS = $(SOURCES:.c=.o)
CPP_OBJECTS = $(CPP_SOURCES:.cpp=.o)
ALL_OBJECTS = $(OBJECTS) $(CPP_OBJECTS)

# Default target
all: $(WRAPPER).so $(WRAPPER).a

# Shared library
$(WRAPPER).so: $(ALL_OBJECTS)
	$(CC) $(LDFLAGS) -o $@ $^ -l$(LIBRARY)

# Static library
$(WRAPPER).a: $(ALL_OBJECTS)
	ar rcs $@ $^

# Compile C source files
%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

# Compile C++ source files
%.o: %.cpp
	$(CXX) $(CXXFLAGS) -c $< -o $@

# Clean
clean:
	rm -f $(ALL_OBJECTS) $(WRAPPER).so $(WRAPPER).a

# Install
install: all
	install -d $(DESTDIR)/usr/lib
	install -d $(DESTDIR)/usr/include
	install -m 644 $(WRAPPER).so $(DESTDIR)/usr/lib/
	install -m 644 $(WRAPPER).a $(DESTDIR)/usr/lib/
	install -m 644 *.h $(DESTDIR)/usr/include/

# Uninstall
uninstall:
	rm -f $(DESTDIR)/usr/lib/$(WRAPPER).so
	rm -f $(DESTDIR)/usr/lib/$(WRAPPER).a
	rm -f $(DESTDIR)/usr/include/raylib*.h

# Test
test: all
	./test_raylib
