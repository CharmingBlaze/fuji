#include "../stdlib/timer.fuji"

// Exercise update() (early return when done + tail return) under a loop — needs
// fuji_pop_frame on every LLVM ret path (see gc_shadow_multi_return_pop).
let t = create(1.0);
let dt = 0.25;
while (!t.done) {
    t = update(t, dt);
}
assert(t.done, "timer finished");
assert(t.elapsed == 1.0, "elapsed at duration");

print("PASS: timer");
