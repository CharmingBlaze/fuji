//   right: // Top border offset int
//   bottom: // Right border offset int
//   layout: // Bottom border offset int
//   3x1: // Layout of the n-patch: 3x3, 1x3 or

// Struct: GlyphInfo
//   value: int
//   offsetX: // Character value (Unicode) int
