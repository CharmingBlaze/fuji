func outer(x) {
    func inner(y) {
        return x + y
    }
    return inner(10)
}

let a = outer(5)
let b = outer(20)
print(a)
print(b)

func makeAdder(n) {
    return func(x) {
        return n + x
    }
}
let add5 = makeAdder(5)
let add10 = makeAdder(10)
print(add5(3))
print(add10(3))
print("PASS")
