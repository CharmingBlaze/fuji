// ----------------------------------------------------------------------------
// raylib
// Fuji library bindings - generated by wrapgen
// Ship this file with your app bundle.
//
// Usage in your Fuji program:
//   #include "raylib.fuji"
//
// Build and bundle:
//   set FUJI_NATIVE_SOURCES=wrapper.c
//   set FUJI_LINKFLAGS=-I<inc> -L<lib> -lraylib
//   kuji build mygame.fuji -o mygame.exe
//   kuji bundle mygame.fuji -o dist/mygame
// ----------------------------------------------------------------------------

// ----------------------------------------------------------------------------
